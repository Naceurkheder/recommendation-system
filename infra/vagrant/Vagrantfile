Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/focal64"
  config.vm.boot_timeout = 600
  config.ssh.insert_key = false

  # 🔹 Host-only network ONLY — no NAT adapter
  config.vm.network "private_network", ip: "192.168.56.10", name: "vboxnet0"

  # 🔹 Port forwarding still works via host-only IP
  config.vm.network "forwarded_port", guest: 8000, host: 8000, host_ip: "192.168.56.1"
  config.vm.network "forwarded_port", guest: 5432, host: 5432, host_ip: "192.168.56.1"
  config.vm.network "forwarded_port", guest: 6379, host: 6379, host_ip: "192.168.56.1"

  config.vm.provider "virtualbox" do |vb|
    vb.memory = "4096"
    vb.cpus = 4
    vb.name = "recsys-vm"
    
    # ✅ Graphics fixes to avoid GUI freeze
    vb.customize ["modifyvm", :id, "--graphicscontroller", "vmsvga"]
    vb.customize ["modifyvm", :id, "--vram", "128"]
    vb.customize ["modifyvm", :id, "--accelerate3d", "off"]
    vb.customize ["modifyvm", :id, "--natdnshostresolver1", "off"]  # avoids DNS hang on boot
  end

  config.vm.synced_folder "../..", "/vagrant", type: "virtualbox"

  config.vm.provision "shell", inline: <<-SHELL
    apt-get update
    apt-get install -y docker.io docker-compose git gcc libomp-dev python3-pip postgresql-client
    usermod -aG docker vagrant
  SHELL
end
