# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://recsys_admin:secure_password@db:5432/recsys_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── AWS / LocalStack ──────────────────────────────────────────────────────────
# All AWS calls target LocalStack — never real AWS endpoints
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localstack:4566

# ── C shared library ──────────────────────────────────────────────────────────
REC_ENGINE_LIB=/usr/local/lib/librec_engine.so
REC_ENGINE_DATA=/vagrant/src/host-cuda/openmp/data/matrix.csv

# ── API tuning ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
OMP_NUM_THREADS=0

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=3600

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG=false
